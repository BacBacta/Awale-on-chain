# Chain wiring
RPC_URL=https://forno.celo-sepolia.celo-testnet.org
CHAIN_ID=11142220
ESCROW_ADDRESS=0x...
VERIFIER_ADDRESS=0x...
# TournamentEscrow (optional). When set, completed brackets are finalised on-chain
# by SERVER_SIGNER_KEY (which must be the contract's operator). Unset ⇒ off-chain log.
TOURNAMENT_ADDRESS=0x...

# Server signer that submits settlements (settleSigned / finalize / voidExpired).
# Keep this key server-side only. Fund it with a little stablecoin for fees.
SERVER_SIGNER_KEY=0x...

# feeCurrency adapter for the network fee (CIP-64). Use the token's adapter
# address (USDC/USDT) or the USDm token address itself.
FEE_CURRENCY=0x...

# Transport
PORT=8080

# Self proof-of-personhood (anti-sybil gate for ranked/cash matchmaking).
# Leave unset to disable the gate. SELF_ENDPOINT must be this server's public
# /self/verify URL, reachable from the Self mobile app — not a local address.
SELF_SCOPE=awale-on-chain
SELF_ENDPOINT=https://your-game-server.example/self/verify
SELF_MOCK_PASSPORT=true
