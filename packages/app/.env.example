# --- Server-side (used by /stats via the indexer) ---
# RPC + deployed MatchEscrow address; without these /stats shows an empty snapshot.
STATS_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
ESCROW_ADDRESS=0x...
ESCROW_FROM_BLOCK=0
CELO_TESTNET=true

# --- Client-side (exposed to the browser; needed to play real matches) ---
# These wire the mini-app to the deployed contracts (joinMatch + move signing).
NEXT_PUBLIC_CHAIN_ID=11142220
NEXT_PUBLIC_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
NEXT_PUBLIC_ESCROW_ADDRESS=0x...
NEXT_PUBLIC_VERIFIER_ADDRESS=0x...
# TournamentEscrow address (optional). Set to enable the Tournaments (Cups) tab.
NEXT_PUBLIC_TOURNAMENT_ADDRESS=0x...
# Cosmetics (ERC-1155 skins) address. Set to open the /shop; unset shows
# "Coming soon". Deployed on Celo Sepolia: 0x82EEf74be9801374F4A5cd3156Fe47cac67B1808
NEXT_PUBLIC_COSMETICS_ADDRESS=0x...
# CIP-64 fee-currency adapter — gas paid in stablecoin inside MiniPay. For the
# shop this defaults to the Cosmetics currency() (aUSD) when unset.
NEXT_PUBLIC_FEE_CURRENCY=0x...
# Game server websocket endpoint
NEXT_PUBLIC_SERVER_URL=https://<your-ngrok-subdomain>.ngrok.app

# Self proof-of-personhood (must match the game server's SELF_SCOPE, and
# NEXT_PUBLIC_SELF_ENDPOINT must be the server's public /self/verify URL).
# Leave unset to disable the gate — MatchActions then shows ungated.
NEXT_PUBLIC_SELF_SCOPE=awale-on-chain
NEXT_PUBLIC_SELF_ENDPOINT=https://your-game-server.example/self/verify
NEXT_PUBLIC_SELF_MOCK_PASSPORT=true
