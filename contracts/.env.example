# Deployer key (required). Use a dedicated deploy key, never a personal wallet.
PRIVATE_KEY=0x...

# Governance owner of Treasury + MatchEscrow (optional; defaults to the deployer).
# Set this to your timelock + multisig before mainnet.
OWNER=0x...

# Parameter overrides (optional; defaults: 250 bps, 600s, 86400s).
# RAKE_BPS=250
# CHALLENGE_WINDOW=600
# MATCH_TTL=86400

# Set this to deploy self-contained mock stablecoins (18/6/6 dec) and allowlist
# them — the easiest way to get a full testnet environment with no external token
# addresses to hunt for. Refused on mainnet. Leave unset to use the addresses
# below. The deployer is seeded with mock balances.
DEPLOY_MOCK_TOKENS=true

# Celo Sepolia stablecoin token addresses (required on 11142220 unless DEPLOY_MOCK_TOKENS=true).
USDM_ADDRESS=0x...
USDC_ADDRESS=0x...
USDT_ADDRESS=0x...

# RPC endpoints
CELO_SEPOLIA_RPC=https://forno.celo-sepolia.celo-testnet.org
CELO_MAINNET_RPC=https://forno.celo.org

# Etherscan V2 (Celoscan) key for contract verification
ETHERSCAN_API_KEY=...
